# Avenue Admin (Digiboard) — environment template
# Copy to .env.production on server. Never commit real secrets.

NODE_ENV=production
PORT=3001

# Internal URL to Avenue backend (Docker: http://avenue:3000)
AVENUE_API_URL=http://avenue:3000

# Must match Avenue ADMIN_API_TOKEN exactly
ADMIN_API_TOKEN=

# Signs admin browser session cookie (can be same as ADMIN_API_TOKEN or separate)
# Generate: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Public customer site link in header ("View Website")
NEXT_PUBLIC_AVENUE_SITE_URL=https://www.example.com
